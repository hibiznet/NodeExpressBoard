<section class="card">
  <div class="post-header">
    <div>
      <div class="meta"><%= post.board_name %> / <%= post.category_name || '-' %></div>
      <h1><%= post.title %></h1>
      <div class="meta">작성자: <%= post.author_name %> | 조회수: <%= post.view_count %> | 좋아요: <%= post.like_count %> | 작성일: <%= dayjs(post.created_at).format('YYYY-MM-DD HH:mm') %></div>
    </div>
    <div class="flex-row">
      <form method="post" action="/boards/<%= post.id %>/like" class="inline-form"><button class="btn btn-outline" type="submit"><%= liked ? '좋아요 취소' : '좋아요' %></button></form>
      <form method="post" action="/boards/<%= post.id %>/share" class="inline-form"><button class="btn btn-outline" type="submit">공유</button></form>
      <% if (currentUser && (String(currentUser.id) === String(post.user_id) || currentUser.role === 'ADMIN')) { %>
        <a class="btn" href="/boards/<%= post.id %>/edit">수정</a>
        <form method="post" action="/boards/<%= post.id %>?_method=DELETE" class="inline-form" onsubmit="return confirm('삭제하시겠습니까?')"><button class="btn btn-dark" type="submit">삭제</button></form>
      <% } %>
    </div>
  </div>
  <article class="content-box"><%- post.content %></article>
  <hr />
  <h3>첨부파일</h3>
  <ul>
    <% files.forEach(file => { %>
      <li><a href="<%= file.file_path %>" target="_blank"><%= file.original_name %></a> (<%= file.file_size %> bytes)</li>
    <% }) %>
    <% if (!files.length) { %><li>첨부파일 없음</li><% } %>
  </ul>
</section>

<section class="card">
  <h2>댓글</h2>
  <form method="post" action="/comments" class="form-grid">
    <input type="hidden" name="post_id" value="<%= post.id %>" />
    <% if (!currentUser) { %>
      <div class="grid-2">
        <label>비회원 이름<input type="text" name="guest_name" required /></label>
        <label>비회원 비밀번호<input type="password" name="guest_password" required /></label>
      </div>
    <% } %>
    <label>댓글 내용<textarea name="content" rows="4" required></textarea></label>
    <button class="btn" type="submit">댓글 등록</button>
  </form>

  <div class="comment-list">
    <% comments.forEach(comment => { %>
      <div class="comment-item <%= comment.parent_comment_id ? 'reply' : '' %>">
        <div class="meta"><strong><%= comment.author_name %></strong> | <%= dayjs(comment.created_at).format('YYYY-MM-DD HH:mm') %></div>
        <p><%= comment.content %></p>

        <details>
          <summary>수정/삭제</summary>
          <div class="grid-2">
            <form method="post" action="/comments/<%= comment.id %>?_method=PUT" class="form-grid">
              <textarea name="content" rows="3" required><%= comment.content %></textarea>
              <% if (!currentUser) { %><input type="password" name="guest_password" placeholder="비밀번호" required /><% } %>
              <button class="btn btn-small" type="submit">수정</button>
            </form>
            <form method="post" action="/comments/<%= comment.id %>?_method=DELETE" class="form-grid">
              <% if (!currentUser) { %><input type="password" name="guest_password" placeholder="비밀번호" required /><% } %>
              <button class="btn btn-small btn-dark" type="submit">삭제</button>
            </form>
          </div>
        </details>

        <details>
          <summary>답글</summary>
          <form method="post" action="/comments" class="form-grid">
            <input type="hidden" name="post_id" value="<%= post.id %>" />
            <input type="hidden" name="parent_comment_id" value="<%= comment.id %>" />
            <% if (!currentUser) { %>
              <div class="grid-2">
                <input type="text" name="guest_name" placeholder="비회원 이름" required />
                <input type="password" name="guest_password" placeholder="비밀번호" required />
              </div>
            <% } %>
            <textarea name="content" rows="3" required placeholder="답글 내용"></textarea>
            <button class="btn btn-small" type="submit">답글 등록</button>
          </form>
        </details>
      </div>
    <% }) %>
  </div>
</section>
